def dijkstra_logistik(graph, depot):
    """Shortest path dari depot.
    
    Big-O:
    - Inisialisasi dist & parent : O(V)
    - Mencari node minimum : O(V) tiap iterasi
    - Relaksasi semua edge : O(E)
    Total: O(V² + E)
    """

    INF = float('inf')

    dist = {v: INF for v in graph.adj}
    parent = {v: None for v in graph.adj}

    dist[depot] = 0
    visited = set()

    while len(visited) < len(graph.adj):

        current = None
        min_dist = INF

        for v in graph.adj:
            if v not in visited and dist[v] < min_dist:
                min_dist = dist[v]
                current = v

        if current is None:
            break

        visited.add(current)

        edge = graph.adj[current]

        while edge:
            neighbor = edge.dest

            if neighbor not in visited:
                new_dist = dist[current] + edge.jarak

                if new_dist < dist[neighbor]:
                    dist[neighbor] = new_dist
                    parent[neighbor] = current

            edge = edge.next

    return dist, parent
